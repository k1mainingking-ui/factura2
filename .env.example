# Пример файла конфигурации
# Скопируйте этот файл как .env и заполните реальными значениями

# Токен Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API ключ для AI (ProxyAPI, OpenAI, DeepSeek и т.д.)
AI_API_KEY=your_ai_api_key_here

# Базовый URL API
# Для ProxyAPI: https://api.proxyapi.ru/openai/v1
# Для DeepSeek: https://api.deepseek.com/v1
# Для OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Модель AI
# Для OpenAI: gpt-4o-mini, gpt-3.5-turbo
# Для DeepSeek: deepseek-chat
AI_MODEL=gpt-4o-mini